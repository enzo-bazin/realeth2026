{
  "manifest_version": 3,
  "name": "IrisWallet",
  "version": "1.0.0",
  "description": "Biometric wallet based on iris recognition",
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["tabs"],
  "host_permissions": [
    "http://localhost:5000/*"
  ]
}
